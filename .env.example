# ===========================================
# CAISO 配置
# ===========================================

# 监控节点 (SP15, NP15, ZP26, PGEB-APND, SDGE-APND, SCE-APND)
CAISO_NODE=SP15

# 市场类型 (DAM=日前, RTM=实时, RTPD=实时15分钟)
CAISO_MARKET=RTM

# 数据获取间隔（秒）
FETCH_INTERVAL=300

# ===========================================
# 网络配置（中国大陆用户重要！）
# ===========================================

# CAISO API 服务器在美国，中国大陆访问需要代理
# 如果没有代理，请设置 USE_MOCK_DATA=true 使用模拟数据

# 是否使用模拟数据（国内无代理时设为 true）
USE_MOCK_DATA=false

# 是否使用代理
USE_PROXY=false

# HTTP 代理地址（例如：http://127.0.0.1:7890）
HTTP_PROXY=

# HTTPS 代理地址（例如：http://127.0.0.1:7890）
HTTPS_PROXY=

# ===========================================
# 数据库配置
# ===========================================

# PostgreSQL 配置
POSTGRES_USER=caiso
POSTGRES_PASSWORD=YourSecurePassword123!  # 请修改！
POSTGRES_DB=caiso_market

# 完整数据库 URL（一般不用改）
DATABASE_URL=postgresql://caiso:YourSecurePassword123!@db:5432/caiso_market

# ===========================================
# 高级配置
# ===========================================

# 回填历史数据天数（首次启动）
BACKFILL_DAYS=7

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 时区
TZ=America/Los_Angeles